run = "cowsay Configure me!"
entrypoint = "README.md"
modules = ["dart-3.3", "java-graalvm22.3", "nodejs-20", "web"]

[nix]
channel = "stable-24_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd aenzbi_invoice && bash build_serve.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
